{
  "ruleName": "IoTToLambdaAndFirehose",
  "sql": "SELECT * FROM 'iot/sensors'",
  "actions": [
    {
      "lambda": {
        "functionArn": "arn:aws:lambda:us-east-1:ACCOUNT_ID:function:iot-mysql-writer"
      }
    },
    {
      "firehose": {
        "deliveryStreamName": "iot-backup-stream",
        "separator": "\n"
      }
    }
  ]
}
